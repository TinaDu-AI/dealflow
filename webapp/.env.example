# 复制此文件为 .env，填入真实值，不要提交 .env 到 git

# 管理员账号（首次启动自动创建）
ADMIN_EMAIL=your-admin@example.com
ADMIN_PHONE=138xxxxxxxx

# 163 邮件 SMTP（用于发送验证码）
SMTP_USER=your-account@163.com
SMTP_PASS=your-163-auth-code

# 阿里云百炼 Qwen API（LLM 功能：Rubric 评分、关键词提取）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ngrok 公网域名（用于手机端访问，可选）
NGROK_DOMAIN=your-subdomain.ngrok-free.dev

# Flask 端口（默认 5173，一般不需要改）
# FLASK_PORT=5173
